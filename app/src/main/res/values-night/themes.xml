<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.RMPlus" parent="Base.Theme.RMPlus">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_soft</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorSurfaceVariant">@color/surface_dark</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:statusBarColor">@color/screen_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <!-- Kill M3 Purple -->
        <item name="colorSurfaceContainer">@color/surface_dark</item>
        <item name="colorSurfaceContainerLow">@color/surface_dark</item>
        <item name="colorSurfaceContainerHigh">@color/surface_dark</item>

        <!-- DatePicker/TimePicker Customization -->
        <item name="android:datePickerDialogTheme">@style/CustomDatePickerDark</item>
        <item name="android:timePickerDialogTheme">@style/CustomTimePickerDark</item>
    </style>

    <style name="CustomDatePickerDark" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowIsFloating">true</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:headerBackground">@color/primary</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/DialogButtonStyleDark</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DialogButtonStyleDark</item>
    </style>

    <style name="CustomTimePickerDark" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowIsFloating">true</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/DialogButtonStyleDark</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DialogButtonStyleDark</item>
    </style>

    <style name="DialogButtonStyleDark" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>