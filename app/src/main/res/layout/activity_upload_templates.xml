<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/screen_bg">

    <!-- HEADER SECTION -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_bg"
        app:elevation="0dp"
        android:outlineProvider="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_back"
                    app:tint="?android:textColorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/title_upload_templates"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?android:textColorPrimary" />
            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENT SECTION -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="180dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SELECT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_select"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?android:textColorPrimary"
                android:layout_marginBottom="8dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp">

                <Spinner
                    android:id="@+id/spinnerSection"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_spinner_modern"
                    android:paddingStart="44dp"
                    android:paddingEnd="16dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_template"
                    app:tint="@color/text_secondary" />
            </FrameLayout>

            <!-- DYNAMIC: Sub-Section Container -->
            <LinearLayout
                android:id="@+id/subSectionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_select_sub_cat"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:textColorPrimary"
                    android:layout_marginBottom="8dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp">

                    <Spinner
                        android:id="@+id/spinnerSubSection"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_spinner_modern"
                        android:paddingStart="44dp"
                        android:paddingEnd="16dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_more"
                        app:tint="@color/text_secondary" />
                </FrameLayout>
            </LinearLayout>

            <!-- AD LINK INPUT (HIDDEN DEFAULT) -->
            <EditText
                android:id="@+id/editAdLink"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input_modern"
                android:hint="@string/msg_enter_ad_link"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:visibility="gone"
                android:inputType="textUri" />

            <!-- DYNAMIC: Festival Date Picker -->
            <LinearLayout
                android:id="@+id/dateContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_festival_date"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:textColorPrimary"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickDate"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:text="@string/btn_pick_date"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_calendar"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary"
                    android:textColor="?android:textColorPrimary"
                    app:backgroundTint="?attr/colorSurface"/>
            </LinearLayout>

            <!-- DYNAMIC: Festival Name Selection -->
            <LinearLayout
                android:id="@+id/festivalNameContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Festival Name"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?android:textColorPrimary"
                    android:layout_marginBottom="8dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp">

                    <Spinner
                        android:id="@+id/spinnerFestivalName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_spinner_modern"
                        android:paddingStart="44dp"
                        android:paddingEnd="16dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_template"
                        app:tint="@color/text_secondary" />
                </FrameLayout>
            </LinearLayout>

            <!-- EXPIRY DATE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_expiry_date_desc"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?android:textColorPrimary"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickExpiry"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="@string/btn_set_expiry"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_calendar"
                app:iconGravity="textStart"
                app:iconTint="@color/primary"
                android:textColor="?android:textColorPrimary"
                app:backgroundTint="?attr/colorSurface"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"/>

            <!-- MEDIA PREVIEW SEPARATOR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E5E7EB"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_media_preview"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="sans-serif-medium"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#E5E7EB"/>
            </LinearLayout>

            <!-- MEDIA PICKER ZONE -->
            <FrameLayout
                android:id="@+id/previewWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="240dp"
                android:background="@drawable/bg_upload_zone_dashed"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/previewImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerInside"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Play Button Overlay -->
                <ImageView
                    android:id="@+id/icPlayVideo"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_video"
                    android:visibility="gone"
                    android:alpha="0.8" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnChangeMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_select"
                            app:tint="@color/primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_change_media"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/placeholderLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#EFF6FF"
                            android:layout_margin="4dp"
                            android:backgroundTint="#EFF6FF"
                            android:elevation="0dp"
                            android:stateListAnimator="@null"
                            android:alpha="1"
                            android:backgroundTintMode="src_over"
                            tools:ignore="UnusedAttribute" />
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_template"
                            app:tint="@color/primary" />
                        
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="top|end"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@color/primary">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="4dp"
                                android:src="@drawable/ic_add"
                                app:tint="@color/white" />
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/no_media_selected"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?android:textColorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="20dp"
                        android:text="@string/image_video_doc"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectImage"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_select_media"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_select"
                        app:iconTint="@color/primary"
                        app:strokeColor="@color/primary"
                        android:textColor="@color/primary"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING SAVE BUTTON AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="32dp"
            android:text="@string/btn_save_continue"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-bold"
            android:textSize="16sp"
            app:cornerRadius="30dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button_gradient_main"
            app:icon="@drawable/ic_arrow_forward_white"
            app:iconGravity="end"
            android:paddingEnd="24dp"
            android:textColor="@color/white"
            app:elevation="0dp"/>

        <include layout="@layout/bottom_nav_layout" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
