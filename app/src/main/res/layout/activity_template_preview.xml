<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_bg"
        app:elevation="0dp"
        android:outlineProvider="none">

        <!-- HEADER (MATCHING ADMIN PANEL/GALLERY) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_template_preview"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary" />

            <!-- SEARCH QUICK LINK -->
            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/text_primary" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- PREVIEW AREA (The Top Hero) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/card_stroke"
                app:cardBackgroundColor="@color/surface_light">

                <FrameLayout
                    android:id="@+id/layPreviewFrame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="340dp">

                    <ImageView
                        android:id="@+id/imgPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter" />

                    <VideoView
                        android:id="@+id/vPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <!-- BOTTOM GRADIENT FOR CONTRAST -->
                    <View
                        android:id="@+id/previewBottomShadow"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_bottom_shadow"
                        android:visibility="gone"/>

                    <!-- PLAY ICON FOR VIDEO -->
                    <FrameLayout
                        android:id="@+id/layPlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone">

                        <View
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_play_glass"/>

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play_arrow_filled"
                            android:tint="#FFFFFF"/>
                    </FrameLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TEMPLATE INFO (Standard Section) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/txtCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Festival Greetings"
                    android:fontFamily="sans-serif-black"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.01" />
            </LinearLayout>

            <!-- MAIN ACTION: EDIT/CUSTOMIZE (Standard Section) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="24dp"
                android:text="@string/btn_edit_now"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconSize="20dp"
                app:iconPadding="10dp"
                app:iconGravity="textStart"
                android:layout_marginBottom="24dp"
                app:backgroundTint="@null"
                android:background="@drawable/bg_3d_gradient_button_16"
                android:textColor="@color/white"
                app:elevation="0dp"
                android:visibility="gone" />

            <!-- QUICK ACTIONS ROW (Standard Section) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="40dp">

                <!-- [Actions remain same as before] -->
                <LinearLayout
                    android:id="@+id/btnFav"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/imgFav"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/btn_star_big_off"
                        app:tint="@color/text_secondary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_fav"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnLike"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/imgLike"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_heart"
                        app:tint="@color/text_secondary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_like"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnEditBottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/text_secondary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_download_modern"
                        app:tint="@color/text_secondary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_save"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM SHEET: SIMILAR TEMPLATES (Google Image Style) -->
    <LinearLayout
        android:id="@+id/bottomSheetSimilar"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:background="@drawable/bg_premium_panel_top_rounded"
        android:orientation="vertical"
        android:elevation="16dp"
        app:behavior_peekHeight="140dp"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- GRABBER FOR SHEET -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#30808080" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_similar_templates"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="16dp"
            android:letterSpacing="-0.01" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSimilar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp"
            android:nestedScrollingEnabled="true"
            android:overScrollMode="never" />

    </LinearLayout>

    <!-- PROGRESS OVERLAY -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:elevation="100dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">
                <TextView
                    android:id="@+id/txtProgressTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Processing..."
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />
                <ProgressBar
                    android:id="@+id/progressBarHorizontal"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:scaleY="3"
                    android:progressTint="#4285F4"
                    android:progressBackgroundTint="#E0E0E0" />
                <TextView
                    android:id="@+id/txtProgressSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0%"
                    android:textSize="13sp"
                    android:gravity="end"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
