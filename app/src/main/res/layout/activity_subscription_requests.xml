<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- PREMIUM HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_subscription_hub"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textColor="?attr/colorOnSurface"
                android:letterSpacing="-0.02" />

            
        </RelativeLayout>

        <!-- MAIN NAVIGATION SWITCH (Crazy 3D Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_tabs_surface"
                android:padding="6dp">

                <View
                    android:id="@+id/mainSelectionIndicator"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_active" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tabRequests"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/tab_requests"
                        android:textAllCaps="true"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/white" />
                    <TextView
                        android:id="@+id/tabManage"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/tab_plan_setup"
                        android:textAllCaps="true"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- PAGE 1: REQUESTS LIST -->
            <LinearLayout
                android:id="@+id/layoutRequests"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- SUB TABS (Pending | Accepted | Rejected) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">

                        <TextView
                            android:id="@+id/pendingBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_filter_chip_selected"
                            android:text="@string/tab_pending"
                            android:gravity="center"
                            android:paddingHorizontal="20dp"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/approvedBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_filter_chip"
                            android:text="@string/tab_accepted"
                            android:gravity="center"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/rejectedBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_filter_chip"
                            android:text="@string/tab_rejected"
                            android:gravity="center"
                            android:paddingHorizontal="20dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </HorizontalScrollView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/requestRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="16dp" />
            </LinearLayout>

            <!-- PAGE 2: MANAGE PLANS -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layoutManage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="invisible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- PLAN CREATION CARD -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#0D000000"
                        app:cardBackgroundColor="@color/surface_light"
                        android:layout_marginBottom="24dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/title_build_plan"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginBottom="20dp"/>

                            <!-- Duration Input (Count + Unit Dropdown) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">

                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="@string/hint_plan_duration"
                                    app:startIconDrawable="@drawable/ic_calendar"
                                    app:startIconTint="@color/primary"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etDurationCount"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="number"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </com.google.android.material.textfield.TextInputLayout>

                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="0dp"/>

                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.2"
                                    android:hint="@string/hint_duration_unit"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                                    <AutoCompleteTextView
                                        android:id="@+id/spinnerDurationUnit"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <!-- Amount -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_base_amount"
                                app:prefixText="₹"
                                app:prefixTextColor="@color/primary"
                                android:layout_marginBottom="12dp"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etAmount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textSize="15sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Discount -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_discount_price"
                                app:startIconDrawable="@drawable/ic_subscription_profile"
                                app:startIconTint="#F59E0B"
                                app:prefixText="₹"
                                android:layout_marginBottom="12dp"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etDiscount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textSize="15sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- UPI ID -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_upi_id"
                                app:startIconDrawable="@drawable/ic_qr_code"
                                app:startIconTint="@color/primary"
                                android:layout_marginBottom="16dp"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etUpiId"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:textSize="15sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Date Picker Option -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginBottom="20dp">
                                <CheckBox
                                    android:id="@+id/cbSpecificDay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_active_specific_date"
                                    android:fontFamily="sans-serif-bold"
                                    android:textSize="14sp"/>
                            <LinearLayout
                                android:id="@+id/cardSpecificDate"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:background="@drawable/bg_input_2"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:layout_marginTop="8dp"
                                android:visibility="gone">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@color/primary"/>
                                <EditText
                                    android:id="@+id/etSpecificDate"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@null"
                                    android:hint="@string/hint_select_specific_day"
                                    android:textSize="15sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:paddingStart="12dp"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:textColor="?attr/colorOnSurface"/>
                            </LinearLayout>
                            </LinearLayout>

                            <!-- Scanner Image Selector -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_scanner_qr_label"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginBottom="12dp"/>

                            <FrameLayout
                                android:id="@+id/btnPickScanner"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:background="@drawable/bg_upload_zone_dashed"
                                android:layout_marginBottom="24dp">
                                <LinearLayout
                                    android:id="@+id/layoutUploadPrompt"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:layout_gravity="center">
                                    <ImageView
                                        android:layout_width="48dp"
                                        android:layout_height="48dp"
                                        android:src="@drawable/ic_gallery_modern"
                                        app:tint="?attr/colorOnSurfaceVariant"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/label_tap_select_qr"
                                        android:textSize="12sp"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:layout_marginTop="8dp"/>
                                </LinearLayout>
                                <ImageView
                                    android:id="@+id/ivScannerPreview"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerInside"
                                    android:padding="2dp"
                                    android:visibility="gone"/>
                            </FrameLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUploadPlan"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:text="@string/btn_publish_plan"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-black"
                                android:textSize="15sp"
                                android:letterSpacing="0.1"
                                app:cornerRadius="16dp"
                                android:background="@drawable/bg_admin_button_3d"
                                app:backgroundTint="@null"
                                android:textColor="@color/white"
                                app:elevation="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- EXISTING PLANS LIST -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_active_inventory"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/plansRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginBottom="100dp"/>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </FrameLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
