<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <!-- FIRST ROW: MENU, USER NAME , NOTIFICATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="4dp">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_more"
            android:padding="12dp"
            android:background="@drawable/bg_header_btn"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="RM Plus"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface"
            android:letterSpacing="-0.01"
            app:layout_constraintEnd_toStartOf="@+id/notifContainer"
            app:layout_constraintStart_toEndOf="@id/btnMenu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <FrameLayout
            android:id="@+id/notifContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/btnNotification"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@android:drawable/ic_popup_reminder"
                android:background="@drawable/bg_header_btn"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/headerBadge"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:minWidth="18dp"
                android:paddingHorizontal="4dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_badge_red"
                android:gravity="center"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SECOND ROW: SEARCH OPTION -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchContainer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="4dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#1A000000"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search_modern"
                app:tint="?attr/colorOnSurfaceVariant" />

            <EditText
                android:id="@+id/searchBox"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search Posts by Topics"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:background="@null"
                android:paddingHorizontal="12dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:inputType="text" />

            <ImageView
                android:id="@+id/btnMic"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

