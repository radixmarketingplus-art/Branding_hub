<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Header Section (Ultra-Compact) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true">

            <!-- Saffron Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="65dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/frame_7_top_right" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:paddingStart="85dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/frame_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COMPANY NAME HERE"
                        android:textColor="@color/white"
                        android:textSize="11.5sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:src="@drawable/ic_call"
                            app:tint="@color/white" />
                        <TextView
                            android:id="@+id/frame_mobile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="+91 00000 00000"
                            android:textColor="@color/white"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Navy Section (Logo) -->
            <RelativeLayout
                android:layout_width="100dp"
                android:layout_height="55dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/frame_7_top_left" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/frame_logo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:scaleType="centerCrop"
                    android:padding="1dp"
                    android:background="@android:color/white"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                    android:src="@drawable/ic_profile" />
            </RelativeLayout>

            <!-- Decorative Navy Bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="42dp"
                android:layout_marginStart="80dp"
                android:background="#001F3F" />
            
            <!-- Thin Accent Bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2.5dp"
                android:layout_marginTop="49.5dp"
                android:layout_marginStart="90dp"
                android:background="#FF9933" />

        </RelativeLayout>

        <!-- Bottom Footer Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_alignParentBottom="true">

            <!-- Side Accent Bars -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_alignParentBottom="true"
                android:background="#FF9933" />

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="180dp"
                android:background="#138808" />

            <!-- Email Trapezoid Center -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_alignParentBottom="true"
                android:layout_marginHorizontal="60dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/frame_7_bottom_center" />

                <TextView
                    android:id="@+id/frame_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="info@company.com"
                    android:textColor="@color/white"
                    android:textSize="9.5sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </RelativeLayout>
        </RelativeLayout>

    </RelativeLayout>
</FrameLayout>
