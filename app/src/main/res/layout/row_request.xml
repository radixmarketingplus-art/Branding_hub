<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/surface_light"
    android:foreground="?attr/selectableItemBackground">

    <!-- AVATAR ICON -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:padding="12dp"
        app:shapeAppearanceOverlay="@style/CircleAppearance"
        android:background="#F0F2F5"
        android:src="@drawable/ic_clipboard_list"
        app:tint="?attr/colorPrimary"/>

    <!-- CONTENT BOX -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/imgIcon"
        android:layout_toStartOf="@id/txtTime"
        android:layout_marginStart="16dp"
        android:layout_centerVertical="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtRequestType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface"
            android:text="Contact Request"/>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="I need help with..."/>
    </LinearLayout>

    <!-- RIGHT SIDE: TIME & STATUS -->
    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="2dp"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="10:30 AM"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#0D000000"
        app:cardBackgroundColor="#F8F9FA">

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:textColor="?attr/colorPrimary"
            android:text="Pending"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/imgIcon"
        android:layout_marginStart="16dp"
        android:background="#0D000000"/>

</RelativeLayout>
