<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="380dp"
    android:layout_height="160dp"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="8dp"
    card_view:cardElevation="4dp"
    card_view:cardBackgroundColor="#1A1A1A"
    android:foreground="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
 
        <!-- FEATURE IMAGE -->
        <ImageView
            android:id="@+id/img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Featured image"/>
 
            <androidx.media3.ui.PlayerView
                android:id="@+id/videoPlayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                card_view:use_controller="false"
                card_view:surface_type="texture_view"
                card_view:resize_mode="zoom"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/pbLoading"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white"
                android:visibility="gone"/>

            <ImageView
                android:id="@+id/btnVolume"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:padding="6dp"
                android:src="@drawable/ic_volume_off"
                android:background="@drawable/bg_volume_btn"
                android:visibility="gone" />
 
    </FrameLayout>

</androidx.cardview.widget.CardView>
