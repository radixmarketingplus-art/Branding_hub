<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".DashboardActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- HEADER -->
            <include
                layout="@layout/header_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp" />

            <!-- SCROLLABLE GRID -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:paddingBottom="100dp"
                    android:paddingHorizontal="12dp">

                    <!-- Grid items should be cards, but keeping IDs on buttons for compatibility -->
                    <!-- Note: The original used Button in GridLayout. I'll use wrapped MaterialButtons for better styling -->

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAds"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Advertisements"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFestival"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Festival Calendar"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_myplaces"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdates"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Latest Updates"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_popup_reminder"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSpecials"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Business Specials"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_preferences"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMotivation"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Motivation"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/btn_star_big_on"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGreetings"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Greetings"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDigitalCards"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Digital Cards"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_agenda"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReelMaker"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:text="Reel Maker"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconGravity="top"
                        app:iconPadding="8dp" />

                </GridLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

        <!-- BADGE -->
        <TextView
            android:id="@+id/badgeText"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_badge_red"
            android:textColor="@color/white"
            android:gravity="center"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:visibility="gone"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="72dp" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_gravity="bottom"
            app:backgroundTint="?attr/colorSurface"
            app:itemIconSize="25dp"
            app:labelVisibilityMode="unlabeled"
            app:itemHorizontalTranslationEnabled="false"
            app:itemIconTint="@color/primary"
            app:itemTextColor="@color/primary"
            app:itemActiveIndicatorStyle="@style/App.Custom.Indicator" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- SIDE DRAWER -->
    <include layout="@layout/view_side_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
