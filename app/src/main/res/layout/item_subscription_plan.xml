<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#0D000000"
    app:cardBackgroundColor="@color/surface_light">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scannerCard"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F8FAFC"
            app:strokeWidth="1dp"
            app:strokeColor="#1A000000"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/planScanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:src="@drawable/ic_gallery_modern" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/scannerCard"
            android:layout_toStartOf="@id/btnDeletePlan"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/planDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Month Plan"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textColor="?attr/colorOnSurface"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/planAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹199"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/primary"/>
                
                <TextView
                    android:id="@+id/planDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Disc: ₹99"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#F59E0B"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDeletePlan"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_button_danger_light"
            android:src="@drawable/ic_delete"
            app:tint="#EF4444"
            android:padding="8dp"/>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
