<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:fitsSystemWindows="true"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="@color/primary"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:toolbarId="@+id/toolbar"
            app:titleEnabled="false">

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fitsSystemWindows="true"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7"
                tools:src="@drawable/bg_placeholder" />

            <!-- Gradient Overlay for readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_gradient_top_to_bottom" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:contentInsetStart="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:padding="10dp"
                        android:src="@drawable/ic_back"
                        android:background="@drawable/bg_circle_glass"
                        app:tint="@color/white" />

                    <TextView
                        android:id="@+id/toolbarTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="Template View"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/btnSearch"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:background="@drawable/bg_circle_glass"
                            app:tint="@color/white" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-30dp"
        android:background="@drawable/bg_bottom_sheet_rounded_30"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Handle Bar -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="#E2E8F0"
                android:alpha="0.5" />

            <!-- INFO SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/btnDelete">

                    <TextView
                        android:id="@+id/txtCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/txtExpiryStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/msg_expiry_loading"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- CIRCULAR DELETE BUTTON ON THE RIGHT -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnDelete"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FEE2E2"
                    app:cardBackgroundColor="#FEF2F2"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="#EF4444" />
                </com.google.android.material.card.MaterialCardView>

            </RelativeLayout>

            <!-- AD BUTTON (Special Case) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenAd"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="20dp"
                android:text="@string/btn_open_ad"
                android:visibility="gone"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                app:elevation="4dp" />

            <!-- DASHBOARD STATS SECTION -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Engagement Overview"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="16dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginBottom="24dp">

                    <!-- LIKES -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statLike"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#FEE2E2"
                        app:cardBackgroundColor="#FEF2F2"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_heart"
                                app:tint="#EF4444" />
                            <TextView
                                android:id="@+id/txtLikeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#B91C1C" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_likes"
                                android:textSize="12sp"
                                android:textColor="#EF4444" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- FAVORITES -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statFav"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#FEF3C7"
                        app:cardBackgroundColor="#FFFBEB"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/btn_star_big_off"
                                app:tint="#F59E0B" />
                            <TextView
                                android:id="@+id/txtFavCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#B45309" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_favorite"
                                android:textSize="12sp"
                                android:textColor="#F59E0B" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- EDITS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statEdit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#DBEAFE"
                        app:cardBackgroundColor="#EFF6FF"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/ic_menu_edit"
                                app:tint="#3B82F6" />
                            <TextView
                                android:id="@+id/txtEditCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#1D4ED8" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_edits"
                                android:textSize="12sp"
                                android:textColor="#3B82F6" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- SAVES -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#D1FAE5"
                        app:cardBackgroundColor="#ECFDF5"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_download_modern"
                                app:tint="#10B981" />
                            <TextView
                                android:id="@+id/txtSaveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#047857" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_saved"
                                android:textSize="12sp"
                                android:textColor="#10B981" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING ACTION BUTTON FOR EDIT (Sticky at bottom for better reach) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEditNow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        android:text="@string/desc_edit"
        android:textSize="16sp"
        android:fontFamily="sans-serif-black"
        android:elevation="12dp"
        app:cornerRadius="24dp"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconSize="24dp"
        app:iconPadding="12dp"
        app:iconGravity="textStart"
        app:backgroundTint="@null"
        android:background="@drawable/bg_3d_gradient_button_16"
        android:textColor="@color/white"
        app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
