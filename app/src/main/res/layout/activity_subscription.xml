<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true">

    <!-- HEADER SECTION -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_bg"
        app:elevation="0dp"
        android:outlineProvider="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="?android:textColorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/menu_subscription"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textColor="?android:textColorPrimary" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="40dp">

            <!-- HERO STATUS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="28dp">

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_subscription_profile"
                        app:tint="?attr/colorPrimary"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_support_icon"
                        android:padding="18dp" />

                    <TextView
                        android:id="@+id/statusTxt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/status_checking"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/planTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/expiryTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PLAN CHOOSER -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionPlanChooser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#0D000000"
                app:cardBackgroundColor="@color/surface_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_choose_plan"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />

                    <Spinner
                        android:id="@+id/planSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_spinner_modern" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- QR PAYMENT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionQrPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#0D000000"
                app:cardBackgroundColor="@color/surface_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_scan_qr"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/upiIdTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upi_id_value"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/amountTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amount: ₹0"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="4dp"
                        app:strokeColor="@color/white">
                        <ImageView
                            android:id="@+id/qrImage"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/qr_1month" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACTIONS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/uploadBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_upload_proof"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-black"
                android:textSize="16sp"
                android:textColor="@color/white"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconTint="@color/white"
                app:cornerRadius="16dp"
                android:background="@drawable/bg_admin_button_3d"
                app:backgroundTint="@null"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/proofCard"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#0D000000">
                <ImageView
                    android:id="@+id/proofPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#1A000000" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/submitBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_submit_request"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp"
                android:textColor="@color/white"
                app:cornerRadius="18dp"
                android:background="@drawable/bg_admin_button_3d"
                app:backgroundTint="@null" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                android:indeterminateTint="?attr/colorPrimary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
