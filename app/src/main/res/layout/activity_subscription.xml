<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00000000"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_premium_plans"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textColor="?attr/colorOnSurface"
                android:letterSpacing="-0.02" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- STATUS HERO AREA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:paddingHorizontal="24dp">

                    <FrameLayout
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginBottom="16dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_support_icon"
                            android:alpha="0.15"/>
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_subscription_profile"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/statusTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_checking"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/planTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.8" />

                    <LinearLayout
                        android:id="@+id/expiryContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_tab_active"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:visibility="gone">
                        <TextView
                            android:id="@+id/expiryTxt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/white"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PLAN CHOOSER SECTION -->
            <LinearLayout
                android:id="@+id/sectionPlanChooser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_select_membership"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/plansRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingHorizontal="4dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- PAYMENT SECTION -->
            <LinearLayout
                android:id="@+id/sectionQrPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#10000000"
                    app:cardBackgroundColor="@color/surface_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="28dp">

                        <!-- HEADER: BLUE TRUST THEME -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginBottom="16dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_admin"
                                app:tint="#2563EB"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_secure_payment"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#1E3A8A" />
                        </LinearLayout>

                        <!-- UPI ID: SUCCESS GREEN THEME -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_upi_pill"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="12dp"
                            android:gravity="center"
                            android:layout_marginBottom="20dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_admin"
                                app:tint="#166534"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:id="@+id/upiIdTxt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="upi@verified"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#166534"
                                android:letterSpacing="0.02" />
                        </LinearLayout>

                        <!-- AMOUNT: GOLDEN / VIBRANT THEME -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginBottom="28dp">
                            <TextView
                                android:id="@+id/originalAmountTxt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="#94A3B8"
                                android:layout_marginBottom="2dp"
                                android:visibility="gone" />
                            <TextView
                                android:id="@+id/amountTxt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="36sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#10B981"
                                android:letterSpacing="-0.03" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_total_to_pay"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="#64748B"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/savingsDetailTxt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_upi_pill"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="You save ₹0"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-bold"
                                android:textColor="#166534"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- QR CODE: THE FINAL DESTINATION -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="6dp"
                            app:strokeWidth="5dp"
                            app:strokeColor="#F8FAFC">
                            <ImageView
                                android:id="@+id/qrImage"
                                android:layout_width="210dp"
                                android:layout_height="210dp"
                                android:padding="16dp"
                                android:scaleType="fitCenter" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PROOF UPLOAD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_payment_confirmation"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/uploadBtn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/btn_upload_screenshot"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    app:icon="@drawable/ic_gallery_modern"
                    app:iconTint="@color/white"
                    app:iconSize="20dp"
                    app:cornerRadius="18dp"
                    android:background="@drawable/bg_admin_button_3d"
                    app:backgroundTint="@null"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/proofCard"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:id="@+id/proofPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/submitBtn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/btn_confirm_subscription"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-black"
                    android:textSize="17sp"
                    android:textColor="@color/white"
                    app:cornerRadius="20dp"
                    android:background="@drawable/bg_admin_button_3d"
                    app:backgroundTint="@null"
                    app:elevation="8dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:indeterminateTint="@color/primary" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
