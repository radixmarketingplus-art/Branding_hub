<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".AdRequestActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- CUSTOM TOP BAR (Back button + Title) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/title_adv_request"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface" />
            </RelativeLayout>

            <!-- SCROLLABLE CONTENT -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="120dp">

                    <!-- Title for the page -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_adv_request"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="20dp" />

                    <!-- ═══════════════════════════════════════════════════
                         STEP 1: WEBSITE LINK
                         ═══════════════════════════════════════════════════ -->

                    <!-- Step Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="1"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_support_icon"
                            android:backgroundTint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_website_redirect_link"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_fill_adv_details"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etLink"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="@string/hint_adv_link"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:background="@drawable/bg_input_2"
                        android:paddingHorizontal="16dp"
                        android:singleLine="true"
                        android:layout_marginBottom="8dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10000000"
                        android:layout_marginVertical="20dp" />

                    <!-- ═══════════════════════════════════════════════════
                         STEP 2: UPLOAD AD TEMPLATE
                         ═══════════════════════════════════════════════════ -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="2"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_support_icon"
                            android:backgroundTint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_upload_adv_template"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>

                    <!-- Upload Zone (Dashed Border) -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@drawable/bg_upload_zone_ad"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:id="@+id/templatePlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                app:tint="?attr/colorPrimary"
                                android:alpha="0.5"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_aspect_ratio_16_9"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/imgTemplate"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:clickable="true"
                            android:focusable="true"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvReCropHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_tap_to_recrop"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorPrimary"
                        android:alpha="0.7"
                        android:visibility="gone"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadTemplate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/btn_upload_template"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary"
                        app:cornerRadius="14dp"
                        app:backgroundTint="#E8EEFF"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconTint="?attr/colorPrimary"
                        app:iconGravity="textStart" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10000000"
                        android:layout_marginVertical="20dp" />

                    <!-- ═══════════════════════════════════════════════════
                         STEP 3: SCAN & PAY
                         ═══════════════════════════════════════════════════ -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="3"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_support_icon"
                            android:backgroundTint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_scan_and_pay"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="@color/white">

                        <ImageView
                            android:id="@+id/imgAdScanner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/qr_1month"
                            android:padding="12dp"
                            android:scaleType="fitCenter" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10000000"
                        android:layout_marginVertical="20dp" />

                    <!-- ═══════════════════════════════════════════════════
                         STEP 4: UPLOAD PAYMENT PROOF
                         ═══════════════════════════════════════════════════ -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="4"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_support_icon"
                            android:backgroundTint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_upload_proof_step"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_optional_payment_desc"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#1A000000">

                        <ImageView
                            android:id="@+id/imgProof"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/proofPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#F8FAFC">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:alpha="0.4"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/msg_payment_screenshot"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.6" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadProof"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/btn_upload_payment_proof"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary"
                        app:cornerRadius="14dp"
                        app:backgroundTint="#E8EEFF"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconTint="?attr/colorPrimary"
                        app:iconGravity="textStart" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="28dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitAd"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/btn_submit_adv_request"
                        android:fontFamily="sans-serif-black"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@null"
                        android:background="@drawable/bg_button_gradient_main" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

        <!-- BOTTOM NAV -->
        <include layout="@layout/bottom_nav_layout"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- SIDE DRAWER -->
    <include layout="@layout/view_side_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
