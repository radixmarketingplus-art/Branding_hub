<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSelection"
    android:layout_width="150dp"
    android:layout_height="180dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="#10000000"
    app:cardBackgroundColor="@color/surface_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <TextView
            android:id="@+id/planBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE 50%"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_tab_active"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/planDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Year"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="4dp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/originalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹999"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:alpha="0.5"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/finalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹499"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/savingsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save ₹500"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/primary"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/ivSelected"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_admin"
            app:tint="@color/primary"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
