<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentTop="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="0dp"
                android:scaleType="fitXY"
                android:src="@drawable/frame_8_top_navy" />

            <!-- Company Name Tag -->
            <RelativeLayout
                android:layout_width="200dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp">
                
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/frame_8_company_tag" />

                <TextView
                    android:id="@+id/frame_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:paddingStart="25dp"
                    android:paddingEnd="35dp"
                    android:text="Company Name"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </RelativeLayout>

            <!-- Profile/Logo Top Right -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/frame_logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="20dp"
                android:padding="2dp"
                android:background="@color/white"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp"
                android:src="@drawable/ic_profile" />
        </RelativeLayout>

        <!-- Footer Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_alignParentBottom="true">

            <!-- Navy Blue Bar (Email) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="120dp"
                android:background="#001F3F">

                <TextView
                    android:id="@+id/frame_email"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="16dp"
                    android:gravity="center_vertical"
                    android:text="info@example.com"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </RelativeLayout>

            <!-- Yellow Bar (Phone) - Reduced Width -->
            <RelativeLayout
                android:layout_width="160dp"
                android:layout_height="38dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/frame_8_bottom_yellow" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/frame_mobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+91 00000 00000"
                        android:textColor="#333333"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_call"
                        app:tint="#333333" />
                </LinearLayout>
            </RelativeLayout>

        </RelativeLayout>

    </RelativeLayout>
</FrameLayout>
