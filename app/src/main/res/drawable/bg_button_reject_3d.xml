<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- PRESSED STATE -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="2dp">
                <shape>
                    <corners android:radius="16dp"/>
                    <gradient
                        android:startColor="#DC2626"
                        android:centerColor="#EF4444"
                        android:endColor="#F87171"
                        android:angle="45"/>
                    <stroke
                        android:width="1dp"
                        android:color="#20FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- NORMAL STATE -->
    <item>
        <layer-list>
            <!-- SHADOW/DEPTH LAYER -->
            <item android:top="4dp">
                <shape>
                    <corners android:radius="16dp"/>
                    <solid android:color="#991B1B"/>
                </shape>
            </item>
            <!-- SURFACE LAYER -->
            <item android:bottom="4dp">
                <shape>
                    <corners android:radius="16dp"/>
                    <gradient
                        android:startColor="#EF4444"
                        android:centerColor="#EF4444"
                        android:endColor="#F87171"
                        android:angle="45"/>
                    <stroke
                        android:width="1dp"
                        android:color="#20FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
